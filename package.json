{
  "name": "deadpions-frontend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "EXPO_HOME=.expo-home expo start",
    "start:offline": "EXPO_HOME=.expo-home expo start --offline",
    "start:local": "EXPO_HOME=.expo-home EXPO_PUBLIC_API_URL=http://localhost:5001/api expo start",
    "android": "EXPO_HOME=.expo-home expo run:android",
    "ios": "EXPO_HOME=.expo-home CP_HOME_DIR=ios/.cocoapods-home expo run:ios",
    "web": "EXPO_HOME=.expo-home expo start --web",
    "test": "node tests/validation.script.mjs",
    "test:jest": "jest",
    "ios:release:archive": "xcodebuild -workspace ios/DeadPions.xcworkspace -scheme DeadPions -configuration Release -sdk iphoneos -archivePath ios/build/DeadPions.xcarchive archive",
    "eas:build:ios": "npx eas build --platform ios --profile production",
    "eas:submit:ios": "npx eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.17.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@reduxjs/toolkit": "^2.5.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.7.9",
    "expo": "^54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "^7.0.10",
    "expo-av": "^16.0.8",
    "expo-constants": "^18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.0",
    "expo-font": "^14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-screen-orientation": "~9.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-web-browser": "^15.0.10",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.2.2",
    "react-native-iap": "^14.7.17",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "^118.0.0",
    "react-redux": "^9.1.0",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@config-plugins/react-native-webrtc": "^9.0.0",
    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "^54.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    },
    "install": {
      "exclude": [
        "react-native-svg"
      ]
    }
  },
  "private": true
}
