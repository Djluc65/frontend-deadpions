{
  "name": "deadpions-frontend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "EXPO_HOME=.expo-home expo start",
    "start:offline": "EXPO_HOME=.expo-home expo start --offline",
    "start:local": "EXPO_HOME=.expo-home EXPO_PUBLIC_API_URL=http://localhost:5001/api expo start",
    "android": "EXPO_HOME=.expo-home expo run:android",
    "android:emu:install": "cd android && TMPDIR=\"$PWD/../.tmp\" GRADLE_USER_HOME=\"$PWD/../.gradle-home\" ./gradlew :app:installDebug -PreactNativeArchitectures=x86_64 -x lint -x test --no-daemon",
    "android:emu:start": "EXPO_HOME=.expo-home expo start --dev-client -c --port 8082",
    "android:emu:open": "\"$HOME/Library/Android/sdk/platform-tools/adb\" shell am start -a android.intent.action.VIEW -d \"exp+deadpions://expo-development-client/?url=http%3A%2F%2F10.0.2.2%3A8082\"",
    "ios": "HOME=$PWD EXPO_HOME=.expo-home CP_HOME_DIR=ios/.cocoapods-home expo run:ios",
    "web": "EXPO_HOME=.expo-home expo start --web",
    "test": "node tests/validation.script.mjs",
    "test:jest": "jest",
    "ios:release:archive": "xcodebuild -workspace ios/DeadPions.xcworkspace -scheme DeadPions -configuration Release -sdk iphoneos -archivePath ios/build/DeadPions.xcarchive archive",
    "eas:build:ios": "npx eas build --platform ios --profile production",
    "eas:submit:ios": "npx eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@lottiefiles/dotlottie-react": "^0.17.15",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@reduxjs/toolkit": "^2.5.0",
    "@stripe/stripe-react-native": "0.38.6",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.7.9",
    "expo": "~52.0.49",
    "expo-apple-authentication": "~7.1.3",
    "expo-auth-session": "~6.0.3",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-screen-orientation": "~8.0.4",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-tracking-transparency": "~5.1.1",
    "expo-web-browser": "~14.0.2",
    "lottie-react-native": "7.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-google-mobile-ads": "^15.8.3",
    "react-native-iap": "14.6.4",
    "react-native-nitro-modules": "0.31.1",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.19.13",
    "react-native-webrtc": "124.0.4",
    "react-redux": "^9.1.0",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@config-plugins/react-native-webrtc": "10.0.0",
    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "~12.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "react-test-renderer": "18.3.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10",
    "postcss": "8.5.10",
    "tar": "7.5.13"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    },
    "install": {
      "exclude": [
        "react-native-svg"
      ]
    }
  },
  "private": true
}
